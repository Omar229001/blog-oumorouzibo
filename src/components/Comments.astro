---
// Giscus — commentaires via GitHub Discussions
// Setup : https://giscus.app → renseigne ton repo, copie les valeurs ci-dessous
// 1. Active les Discussions sur ton repo GitHub
// 2. Va sur https://giscus.app, sélectionne ton repo
// 3. Remplace les 3 valeurs PLACEHOLDER ci-dessous
---

<section class="comments-section">
  <p class="comments-title">Commentaires</p>
  <script
    src="https://giscus.app/client.js"
    data-repo="GITHUB_USER/GITHUB_REPO"
    data-repo-id="REPO_ID"
    data-category="General"
    data-category-id="CATEGORY_ID"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="0"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="fr"
    crossorigin="anonymous"
    async
    is:inline
  ></script>
</section>
