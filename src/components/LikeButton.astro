---
const { slug } = Astro.props;
---

<div class="like-section">
  <button class="like-btn" id="like-btn" data-slug={slug} aria-label="Aimer cet article">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path class="heart-fill" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="currentColor"/>
      <path class="heart-stroke" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5"/>
    </svg>
    <span id="like-label">J'aime cet article</span>
  </button>
</div>

<script>
  const btn = document.getElementById('like-btn') as HTMLButtonElement;
  const label = document.getElementById('like-label') as HTMLSpanElement;
  const slug = btn.dataset.slug!;
  const key = `liked-${slug}`;

  function update(liked: boolean) {
    btn.classList.toggle('liked', liked);
    label.textContent = liked ? 'Article aimé' : "J'aime cet article";
    btn.setAttribute('aria-pressed', String(liked));
  }

  update(localStorage.getItem(key) === 'true');

  btn.addEventListener('click', () => {
    const liked = localStorage.getItem(key) === 'true';
    localStorage.setItem(key, String(!liked));
    update(!liked);
  });
</script>
